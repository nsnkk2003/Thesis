import cv2

def find_laser_time(video_path):
    cap = cv2.VideoCapture(video_path)
    
    print("--- CONTROLS ---")
    print("[Spacebar] : Pause or Play")
    print("[ n ]      : Step forward exactly ONE frame (only works when paused)")
    print("[ q ]      : Quit and close the window")
    
    paused = False

    while cap.isOpened():
        if not paused:
            ret, frame = cap.read()
            if not ret:
                print("End of video reached.")
                break

        # Read the exact hardware reality timestamp
        msec = cap.get(cv2.CAP_PROP_POS_MSEC)

        # Draw the timestamp on the screen so you can read it easily
        display_frame = frame.copy()
        cv2.putText(display_frame, f"Exact Time: {msec:.2f} ms", (50, 50), 
                    cv2.FONT_HERSHEY_SIMPLEX, 1.5, (0, 255, 0), 3)

        # Show the window
        cv2.imshow("Laser Finder - Press Space to Pause", display_frame)

        # Wait for you to press a key
        key = cv2.waitKey(30 if not paused else 0) & 0xFF

        if key == ord('q'):    # Quit
            break
        elif key == ord(' '):  # Pause/Play
            paused = not paused
        elif key == ord('n') and paused:  # Next Frame
            ret, frame = cap.read()
            if not ret: break

    cap.release()
    cv2.destroyAllWindows()

# --- RUN IT ---
find_laser_time("20240520-082227832807.webm")
